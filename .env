# ==============================
#  VOICEVOX Bot 環境変数設定
# ==============================

# Discordボットトークン (必須)
# https://discord.com/developers/applications でBotを作成して取得
DISCORD_TOKEN=

# VOICEVOXエンジンのURL (デフォルト: localhost:50021)
VOICEVOX_URL=http://localhost:50021

# デフォルト話者ID
# 0=四国めたん 1=ずんだもん 2=春日部つむぎ 3=雨晴はう 4=波音リツ
# !speaker コマンドで全一覧を確認できます
DEFAULT_SPEAKER=1

# 1回の読み上げ最大文字数 (超えた分は「以下省略」)
MAX_TEXT_LENGTH=100
